
# Bob Ignore File - Sensitive Files and Directories
# This file tells Bob to ignore sensitive files containing credentials, keys, and secrets

# Kubernetes and GCP Authentication
kube.config
gke_gcloud_auth_plugin_cache
**/kubeconfig
**/.kube/config

# Service Account Keys and Credentials
**/*-key.json
**/db-user-key.json
**/*-service-account.json
**/*credentials*.json

# Terraform State Files (may contain sensitive data)
**/terraform.tfstate
**/terraform.tfstate.backup
**/.terraform/
**/terraform.tfvars
!**/terraform.tfvars.example

# Secret Files
**/secret.txt
**/secrets.txt
**/.secrets
**/creds.txt

# Environment Files
**/.env
**/.env.local
**/.env.*.local
!**/.env.example

# Private Keys and Certificates
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/id_rsa
**/id_dsa
**/id_ecdsa
**/id_ed25519

# Password and Token Files
**/password.txt
**/passwords.txt
**/token.txt
**/tokens.txt

# Cloud Provider Credentials
**/.aws/credentials
**/.azure/credentials
**/.gcloud/credentials

# Configuration Files with Sensitive Data
f.json
**/config.json
!**/config.example.json

# Secrets Baseline (contains secret detection results)
.secrets.baseline

# Backup and Temporary Files
**/*.bak
**/*.backup
**/*~

# Log Files (may contain sensitive information)
**/*.log
**/logs/

# Database Files
**/*.db
**/*.sqlite
**/*.sqlite3

# IDE and Editor Files
**/.vscode/settings.json
**/.idea/

# OS Files
.DS_Store
Thumbs.db

# Application-Specific Secret Files (boundary-ap-server)
**/boundary_password
**/slack_bot_token
**/azure_client_secret
**/api_token
