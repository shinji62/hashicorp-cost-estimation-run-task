# HCP Terraform Cost Estimation Run Task Configuration

# Log Level (optional)
# Controls the verbosity of logging output
# Options: DEBUG, INFO, WARN, ERROR
# Default: INFO
LOG_LEVEL=INFO

# Log Format (optional)
# Controls the format of logging output
# Options: text, json
# Default: text
LOG_FORMAT=text

# PostgreSQL password for c3x pricing API database
POSTGRES_PASSWORD=changeme

# Budget limit in USD (optional)
# If set, runs exceeding this monthly cost will fail
# Example: C3X_BUDGET_LIMIT=1000.00
C3X_BUDGET_LIMIT=

# C3X Pricing API endpoint (optional)
# Default: http://localhost:4000
# For docker-compose: http://c3x-pricing-api:4000
C3X_PRICING_API_ENDPOINT=http://c3x-pricing-api:4000

# C3X API Key (optional)
# Set if your c3x pricing API requires authentication
# SECURITY NOTE: The API key is handled securely using temporary files
# with restricted permissions to prevent exposure in process listings
C3X_API_KEY=

# Alternative: C3X API Key File (optional, more secure)
# Path to a file containing the API key with restricted permissions (0600)
# If both C3X_API_KEY and C3X_API_KEY_FILE are set, the file takes precedence
# Can also be provided via --c3x-api-key-file CLI flag
# C3X_API_KEY_FILE=/path/to/secure/api-key-file

# Save marshaled Terraform plan JSON to a temp file for replay debugging (optional)
# Set to "true" to keep a secure temp file on disk for inspection during debugging
# Default: false
C3X_SAVE_DEBUG_PLAN=false

# Google Cloud API Key (optional)
# Required for scraping GCP pricing data
# Get one from: https://console.cloud.google.com/apis/credentials
# Can also be provided via --gcp-api-key-file CLI flag for file-based secrets
GCP_API_KEY=

# HMAC Key for request validation (required for production)
# This should match the HMAC key configured in HCP Terraform
# Generate a secure random string for production use
# Can also be provided via --hmac-key CLI flag or --hmac-key-file for file-based secrets
HMAC_KEY=secret123

# ============================================
# AI Agent Configuration
# ============================================

# Google API Key for Gemini AI (required for AI agents)
# Get one from: https://aistudio.google.com/app/apikey
# IMPORTANT: The ADK library requires this to be set as an environment variable.
# File-based secrets are NOT supported for Gemini API keys.
GOOGLE_API_KEY=
# Alternative: GEMINI_API_KEY=

# Gemini model to use for AI agents (default: gemini-3.1-flash-lite)
# Available models: gemini-3.1-flash-lite, gemini-2.0-flash-exp, etc.
GEMINI_MODEL=gemini-3.1-flash-lite

# Enable/disable specific AI agents
# Security Risk Analyzer - identifies security vulnerabilities
AGENT_SECURITY_ENABLED=false

# Pricing Optimization Advisor - provides cost savings recommendations
AGENT_PRICING_ENABLED=false

# Compliance Checker - checks compliance with industry standards
AGENT_COMPLIANCE_ENABLED=false

# Agent behavior configuration
# Set to "true" to fail the run task if agents find critical security issues
AGENT_FAIL_ON_CRITICAL=false

# ============================================
# Command Line Arguments
# ============================================
# The following configuration options can also be provided via command line flags:
#
# Server Configuration:
#   --addr <port>              Server port (default: 22180)
#   --path <path>              URL path for run task (default: /runtask)
#   --log-level <level>        Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
#   --log-format <format>      Log format: text, json (default: text)
#
# Secret Files (more secure than environment variables):
#   --hmac-key-file <path>           Path to file containing HMAC key
#   --c3x-api-key-file <path>        Path to file containing C3X API key
#   --gcp-api-key-file <path>        Path to file containing GCP API key
#
# Note: Google/Gemini API keys MUST be set as environment variables (GOOGLE_API_KEY or GEMINI_API_KEY)
# because the ADK library does not support file-based secrets for these keys.
#
# Priority Order (highest to lowest):
#   1. Command line arguments
#   2. Secret files (via --*-file flags or *_FILE env vars)
#   3. Environment variables
#   4. Default values
#
# Example usage with secret files:
#   ./cost-estimation-run-task \
#     --addr 8080 \
#     --hmac-key-file /secrets/hmac-key \
#     --c3x-api-key-file /secrets/c3x-api-key